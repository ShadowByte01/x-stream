# Xstream — environment variables (Vite uses the VITE_ prefix)

# TMDB API key — get one free at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Groq API key — get one free at https://console.groq.com/keys (for AI recommendations)
VITE_GROQ_API_KEY=your_groq_api_key_here
